<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>ai.talweg</groupId>
  <artifactId>flinkflow</artifactId>
  <version>0.9.0-BETA</version>
  <packaging>jar</packaging>

  <name>flinkflow</name>
  <description>Declarative, Kubernetes-native Stream Processing on Apache Flink.</description>
  <url>https://github.com/talweg/flinkflow</url>

  <licenses>
    <license>
      <name>Apache License, Version 2.0</name>
      <url>https://www.apache.org/licenses/LICENSE-2.0.txt</url>
      <distribution>repo</distribution>
    </license>
  </licenses>

  <developers>
    <developer>
      <id>talweg</id>
      <name>Talweg Core Team</name>
      <email>contact@talweg.ai</email>
      <organization>Talweg</organization>
      <organizationUrl>https://talweg.ai</organizationUrl>
    </developer>
  </developers>

  <scm>
    <connection>scm:git:git://github.com/talweg/flinkflow.git</connection>
    <developerConnection>scm:git:ssh://github.com:talweg/flinkflow.git</developerConnection>
    <url>https://github.com/talweg/flinkflow/tree/main</url>
  </scm>

  <issueManagement>
    <system>GitHub Issues</system>
    <url>https://github.com/talweg/flinkflow/issues</url>
  </issueManagement>

  <properties>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
    <flink.version>1.18.1</flink.version>
    <target.java.version>17</target.java.version>
    <scala.binary.version>2.12</scala.binary.version>
    <maven.compiler.release>${target.java.version}</maven.compiler.release>
    <log4j.version>2.25.3</log4j.version>
    <netty.version>4.1.132.Final</netty.version>
  </properties>

  <repositories>
    <repository>
      <id>confluent</id>
      <url>https://packages.confluent.io/maven/</url>
    </repository>
  </repositories>

